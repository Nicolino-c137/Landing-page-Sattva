---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import MarqueeSection from '../components/MarqueeSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import GallerySection from '../components/GallerySection.astro';
import LocationSection from '../components/LocationSection.astro';
import ReservaSection from '../components/ReservaSection.astro';
import FooterSection from '../components/FooterSection.astro';
---

<BaseLayout
  title="Sattva Spa Integral — Al servicio de tu bienestar"
  description="El primer Spa en San Juan especializado en obsequios de bienestar. Circuitos de spa, masoterapia, reiki, hidroterapia, yoga y más. San Juan, Argentina."
>
  <Nav />

  <main>
    <HeroSection />
    <MarqueeSection />
    <AboutSection />
    <ServicesSection />
    <GallerySection />
    <LocationSection />
    <ReservaSection />
  </main>

  <FooterSection />
</BaseLayout>

<script>
  import('../scripts/scroll-animations');
</script>
