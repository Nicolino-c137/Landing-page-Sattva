---
const MAPS_EMBED = 'https://maps.google.com/maps?q=San+Rafael+1739+Oeste,+San+Juan,+Argentina&z=17&output=embed';
---

<section id="ubicacion" class="section py-24 lg:py-32 px-4 sm:px-6 lg:px-8" style="background-color: #F9F7F2;">
  <div class="wrapper">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Info -->
      <div class="fade-in">
        <p class="label-text mb-4" style="color: #7D8F69;">Dónde encontrarnos</p>
        <h2 class="heading-lg text-ink" style="margin-bottom: 2.5rem;">Ubicación</h2>

        <div style="display: flex; flex-direction: column; gap: 2rem;">

          <!-- Dirección -->
          <div style="display: flex; align-items: flex-start; gap: 1rem;">
            <div style="color: #7D8F69; flex-shrink: 0; margin-top: 3px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="label-text" style="color: #7D8F69; margin-bottom: 0.4rem;">Dirección</p>
              <p class="body-lg" style="color: #2C2C2C;">
                San Rafael 1739 Oeste<br />J5400 Este, San Juan
              </p>
            </div>
          </div>

          <!-- Horarios -->
          <div style="display: flex; align-items: flex-start; gap: 1rem;">
            <div style="color: #7D8F69; flex-shrink: 0; margin-top: 3px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <p class="label-text" style="color: #7D8F69; margin-bottom: 0.4rem;">Horarios de Atención</p>
              <p class="body-lg" style="color: #2C2C2C;">Lunes a Viernes &nbsp;·&nbsp; 14:00 — 20:00</p>
              <p class="body-lg" style="color: #2C2C2C;">Sábados &nbsp;·&nbsp; 09:00 — 20:00</p>
              <p class="body-lg" style="color: #a0a0a0;">Domingos &nbsp;·&nbsp; Cerrado</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Map -->
      <div class="overflow-hidden rounded-2xl shadow-lg fade-in" style="height: 440px;">
        <iframe
          src={MAPS_EMBED}
          width="100%"
          height="100%"
          style="border: 0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Sattva Spa Integral en Google Maps"
        ></iframe>
      </div>

    </div>
  </div>
</section>
