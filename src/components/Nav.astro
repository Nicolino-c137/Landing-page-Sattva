---
const navLinks = [
  { href: '/#sobre-nosotros', label: 'Nosotros' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#inmersion', label: 'Inmersión' },
  { href: '/#ubicacion', label: 'Ubicación' },
];

const INSTAGRAM = 'https://www.instagram.com/sattva_spa_integral';
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50">
  <nav style="margin-top: 0.8rem; margin-bottom:0.8rem;" class="flex items-center justify-between px-8 sm:px-6 py-7 w-full">

    <!-- Logo + nombre -->
    <a href="/" style= "margin-left: 1rem;" class="flex items-center gap-3" aria-label="Inicio — Sattva Spa Integral">
      <img id="nav-logo-img" src="/logo-outline.svg" alt="" class="h-9 w-auto transition-all duration-300" />
      <span
        id="nav-brand-text"
        class="hidden sm:block text-white transition-colors duration-300"
        style="font-family: 'Noto Serif', Georgia, serif; font-size: 0.95rem; font-style: italic; letter-spacing: 0.02em;"
      >
        Sattva Spa Integral
      </span>
    </a>

    <!-- Links desktop -->
    <ul class="hidden md:flex gap-10">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="label-text text-white hover:text-white/60 transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-4" style="margin-right: 1rem;">
      <!-- Instagram CTA desktop -->
      <a
        href={INSTAGRAM}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 btn-outline-light"
        aria-label="Instagram de Sattva Spa Integral"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        Instagram
      </a>

      <!-- Hamburger mobile -->
      <button
        id="menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="line1"></span>
        <span class="block w-6 h-0.5 bg-white transition-all duration-300" id="line2"></span>
        <span class="block w-4 h-0.5 bg-white transition-all duration-300" id="line3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden backdrop-blur-lg border-t"
    style="background-color: rgba(249,247,242,0.97); border-color: #E5DED1;"
  >
    <ul class="flex flex-col px-6 py-8 gap-6 items-center text-center">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="label-text transition-colors duration-200 block"
            style="color: #2C2C2C;"
            onmouseover="this.style.color='#7D8F69'"
            onmouseout="this.style.color='#2C2C2C'"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href={INSTAGRAM}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary flex items-center gap-2"
          style="margin-bottom: 1rem;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          Instagram
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById('main-nav');
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const line3 = document.getElementById('line3');
  const brandText = document.getElementById('nav-brand-text');
  const logoImg = document.getElementById('nav-logo-img') as HTMLImageElement | null;
  const navLinks = nav?.querySelectorAll('ul:first-of-type a');
  const instagramBtn = nav?.querySelector('a[href*="instagram"]') as HTMLElement | null;
  const hamburgerLines = menuBtn?.querySelectorAll('span');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      nav?.classList.add('scrolled');
      navLinks?.forEach(a => {
        a.classList.remove('text-white', 'hover:text-white/60');
        a.classList.add('text-ink', 'hover:text-primary');
      });
      if (brandText) brandText.style.color = '#2C2C2C';
      if (logoImg) logoImg.src = '/logo.svg';
      if (instagramBtn) {
        instagramBtn.classList.remove('btn-outline-light');
        instagramBtn.classList.add('btn-primary');
      }
      hamburgerLines?.forEach(l => (l as HTMLElement).style.backgroundColor = '#7D8F69');
    } else {
      nav?.classList.remove('scrolled');
      navLinks?.forEach(a => {
        a.classList.add('text-white', 'hover:text-white/60');
        a.classList.remove('text-ink', 'hover:text-primary');
      });
      if (brandText) brandText.style.color = 'white';
      if (logoImg) logoImg.src = '/logo-outline.svg';
      if (instagramBtn) {
        instagramBtn.classList.add('btn-outline-light');
        instagramBtn.classList.remove('btn-primary');
      }
      hamburgerLines?.forEach(l => (l as HTMLElement).style.backgroundColor = 'white');
    }
  }, { passive: true });

  let menuOpen = false;
  menuBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu?.classList.toggle('hidden', !menuOpen);
    menuBtn.setAttribute('aria-expanded', String(menuOpen));
    if (line3) line3.style.width = menuOpen ? '1.5rem' : '1rem';
  });

  mobileMenu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
      if (line3) line3.style.width = '1rem';
    });
  });
</script>
