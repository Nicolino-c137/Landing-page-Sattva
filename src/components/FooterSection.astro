---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const year = new Date().getFullYear();

const navLinks = [
  { href: '/#sobre-nosotros', label: 'Nosotros' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#inmersion', label: 'Inmersión' },
  { href: '/#ubicacion', label: 'Ubicación' },
  { href: '/#reserva', label: 'Reservar' },
];

const socials = [
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/sattva_spa_integral',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/sattvasalonyspa',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  },
  {
    label: 'WhatsApp',
    href: 'https://api.whatsapp.com/send/?phone=2644130566&text&type=phone_number&app_absent=0',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
  },
];
---

<footer class="section" style="padding-top: 1.5rem; background-color: #2C2C2C; color: #F9F7F2;">
  <div class="wrapper px-4 sm:px-6 lg:px-8 pt-24 pb-16">

    <div class="grid md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <img src={`${base}logo-outline.svg`} alt="" class="h-11 w-auto brightness-0 invert" />
          <span style="font-family: 'Noto Serif', Georgia, serif; font-size: 1rem; font-style: italic; color: #F9F7F2; letter-spacing: 0.02em;">
            Sattva Spa Integral
          </span>
        </div>
        <p class="body-lg" style="color: rgba(249,247,242,0.6); font-size: 0.9rem; line-height: 1.7;">
          Al servicio de tu bienestar.<br />
          San Juan, Argentina.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <p class="label-text mb-6" style="color: #7D8F69;">Secciones</p>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="body-lg transition-colors duration-200"
                style="color: rgba(249,247,242,0.65); font-size: 0.9rem;"
                onmouseover="this.style.color='#C9A67B'"
                onmouseout="this.style.color='rgba(249,247,242,0.65)'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <p class="label-text mb-6" style="color: #7D8F69;">Seguinos</p>
        <div class="flex flex-col gap-4">
          {socials.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 transition-colors duration-200"
              style="color: rgba(249,247,242,0.65);"
              aria-label={s.label}
              onmouseover="this.style.color='#C9A67B'"
              onmouseout="this.style.color='rgba(249,247,242,0.65)'"
            >
              <Fragment set:html={s.icon} />
              <span class="label-text" style="color: inherit;">{s.label}</span>
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-8"
      style="margin-top: 1.5rem; border-top: 1px solid rgba(249,247,242,0.1);"
    >
      <p class="label-text" style="color: rgba(249,247,242,0.35);">
        © {year} Sattva Spa Integral. Todos los derechos reservados.
      </p>
      <p class="label-text" style="color: rgba(249,247,242,0.2);">
        San Rafael 1739 Oeste, San Juan
      </p>
    </div>

  </div>
</footer>
